{
  "name": "focus-guard",
  "version": "1.0.0",
  "description": "Windows tray app that intercepts distracting URLs with full-screen reminders",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.focusguard.app",
    "productName": "Focus Guard",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "extraResources": [
      {
        "from": "extension",
        "to": "extension"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
